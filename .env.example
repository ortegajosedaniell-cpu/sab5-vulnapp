# Renombrar este archivo a .env y completar los valores

# Puerto del servidor (por defecto 3000)
PORT=3000

# Secreto para JWT (cambiar por algo aleatorio y largo)
JWT_SECRET=cambiar_por_una_clave_secreta_muy_larga_y_aleatoria

# Clave API de Anthropic (Claude) para generación IA del informe
# Obtenerla en: https://console.anthropic.com
# Sin esta clave el sistema funciona igual pero sin generación automática
ANTHROPIC_API_KEY=sk-ant-...
